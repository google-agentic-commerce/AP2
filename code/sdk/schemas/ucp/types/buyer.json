{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ap2-protocol.org/schemas/types/buyer.json",
  "title": "Buyer",
  "description": "Representation of the buyer. Matches UCP types/buyer.json (2026-04-08).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "first_name": {
      "type": "string",
      "description": "First name of the buyer."
    },
    "last_name": {
      "type": "string",
      "description": "Last name of the buyer."
    },
    "email": {
      "type": "string",
      "description": "Email of the buyer."
    },
    "phone_number": {
      "type": "string",
      "description": "E.164 standard."
    }
  }
}
